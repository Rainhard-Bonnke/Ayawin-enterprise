PORT=4000
DATABASE_URL=
DATABASE_SSL=false
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=postgres
DATABASE_PASSWORD=postgres
DATABASE_DB=martin_enterprise

# Redis (sessions & permission cache; optional in local dev)
REDIS_URL=
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

ENABLE_DEMO_MODE=false
NODE_ENV=development

# JWT (Module 1 auth)
JWT_SECRET=your_jwt_secret_here_min_32_chars
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES_DAYS=7
JWT_EXPIRES_IN=8h

# Admin bootstrap
ADMIN_EMAIL=admin@martin.co.ke
ADMIN_USERNAME=admin
ADMIN_FULL_NAME=System Administrator
ADMIN_PASSWORD=

# MFA secret encryption (32-byte key recommended; falls back to JWT_SECRET hash)
MFA_ENCRYPTION_KEY=

# Security
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=300
AUTH_RATE_LIMIT_MAX=20
MAX_FAILED_LOGINS=5

# SSO (Module 1 stubs — wire providers in Module 8)
OAUTH_GOOGLE_CLIENT_ID=
OAUTH_GOOGLE_CLIENT_SECRET=
SAML_ENTRY_POINT=
SAML_CERT=

# Integrations (Module 8)
ETIMS_ENABLED=false
MPESA_CONSUMER_KEY=
MPESA_CONSUMER_SECRET=
MPESA_SHORTCODE=
SENDGRID_API_KEY=
AFRICASTALKING_API_KEY=
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
